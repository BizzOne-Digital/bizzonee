# ─── Contact form (email) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your16charapppassword
CONTACT_TO=leads@yourbusiness.com

# ─── Web-dev onboarding form (submits straight into ClickUp) ───
# Personal API token: ClickUp > Settings > Apps > "Generate" (starts with pk_...)
CLICKUP_TOKEN=pk_xxxxxxxx_YOURTOKEN
# The List ID where onboarding tasks are created (the list your ClickUp form feeds).
# Open that list in ClickUp; the ID is in the URL, or use the list your old form used.
CLICKUP_LIST_ID=901327224920
